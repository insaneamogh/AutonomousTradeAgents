{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-native",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@app/ui": ["../../packages/ui/src"],
      "@app/ui/*": ["../../packages/ui/src/*"],
      "@app/shared-types": ["../../packages/shared-types/src"],
      "@app/shared-types/*": ["../../packages/shared-types/src/*"]
    }
  },
  "include": ["app/**/*", "src/**/*", "*.ts", "*.tsx"],
  "exclude": ["node_modules", ".expo", "dist"]
}
