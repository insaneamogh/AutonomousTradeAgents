# Mobile-side env. Copy to apps/mobile/.env (gitignored) for Expo dev.
#
# Vars prefixed with EXPO_PUBLIC_ are compiled into the bundle + readable
# at runtime via process.env. Anything not prefixed is dev-time only.

# Point the app at your API. Without this, src/lib/api.ts falls back to:
#   - Expo dev server's host (LAN IP) on a real device
#   - http://10.0.2.2:8000 (Android emulator) / localhost (iOS sim)
#
# For Railway:
EXPO_PUBLIC_API_URL=https://your-app.railway.app

# For local dev pointing at the host machine over LAN:
# EXPO_PUBLIC_API_URL=http://192.168.1.42:8000
