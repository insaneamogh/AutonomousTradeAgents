# ── API runtime ──────────────────────────────────────────────────────
ENV=local                              # local | staging | production
LOG_LEVEL=INFO
JWT_SECRET=change-me-locally-32-bytes-min
CORS_ORIGINS=*                         # explicit comma-list in production

# ── Storage ──────────────────────────────────────────────────────────
USE_POSTGRES=0                         # 1 = Postgres-backed stores (needs DATABASE_URL + `make migrate`)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/autotrader

# ── Reconciler fleet (per-user, real broker) ─────────────────────────
RECONCILER_ENABLED=1
RECONCILER_INTERVAL_SECONDS=30
DRAWDOWN_HALT_THRESHOLD_PCT=-3.0

# ── Trading mode ─────────────────────────────────────────────────────
TRADING_MODE=paper                     # paper (default) | live
LIVE_TRADING_ENABLED=0                 # 1 + TRADING_MODE=live = real money. Deliberate, audited.

# ── Broker: Alpaca ───────────────────────────────────────────────────
# Data keys (bars for features + ghost marks). Data-only keys work.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# OAuth app credentials (user connections)
ALPACA_OAUTH_CLIENT_ID=
ALPACA_OAUTH_CLIENT_SECRET=
ALPACA_OAUTH_REDIRECT_URI=autotrader://broker/callback
# Token encryption at rest (32-byte base64; Doppler in prod)
BROKER_TOKEN_ENCRYPTION_KEY=

# ── Broker: Zerodha (DARK in v1 — India is v2 + SEBI review) ─────────
KITE_API_KEY=
KITE_API_SECRET=

# ── Agents / LLM ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                     # empty → deterministic MOCK council (dev/CI)
LLM_TEMPERATURE=0.0                    # council variance comes from the market, not the sampler
LLM_TIMEOUT_SECONDS=60
AGENTS_REQUIRE_REAL_LLM=0              # 1 = hard-fail instead of mock (SET IN PRODUCTION)
AGENTS_REQUIRE_REAL_DATA=0             # 1 = hard-fail instead of synthetic features (SET IN PRODUCTION)

# ── Market data: features ────────────────────────────────────────────
FRED_API_KEY=                          # free key — VIX / 10y / dollar for the Macro Analyst

# ── Daily council cron ───────────────────────────────────────────────
AGENT_CRON_USER_ID=00000000-0000-0000-0000-000000000001
AGENT_CRON_WATCHLIST=SPY,QQQ,AAPL,NVDA,MSFT,GOOG,AMZN,META,TSLA,JPM
# AGENT_APPROVAL_TTL_MINUTES=          # unset → proposals live until ~market close (21:00 UTC)

# ── Auth (dev) ───────────────────────────────────────────────────────
DEV_AUTH_BYPASS=0                      # 1 = fixture user without Bearer (dev only)
